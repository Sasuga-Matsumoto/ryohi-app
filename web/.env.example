# Supabase (https://supabase.com で無料プロジェクト作成後に取得)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (https://dash.cloudflare.com の R2 で作成・S3 API 互換キー)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ryohi-evidence

# Inngest (https://www.inngest.com 無料プラン)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# OSM Nominatim (User-Agent 必須)
NOMINATIM_USER_AGENT=ryohi-app/0.1 (your-email@example.com)
