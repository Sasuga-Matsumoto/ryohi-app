{
  "expo": {
    "name": "Log Tracker",
    "slug": "plex-shucho-log",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "ryohi",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.plex.shuchologu",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "出張記録のため、常に位置情報が必要です。業務時間外でも勤務地・自宅の出入りだけ検知します。",
        "NSLocationAlwaysUsageDescription": "出張記録のため、常に位置情報が必要です。",
        "NSLocationWhenInUseUsageDescription": "出張記録のため、位置情報が必要です。",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "processing",
          "location",
          "fetch",
          "processing"
        ]
      }
    },
    "android": {
      "package": "com.plex.shuchologu",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "WAKE_LOCK",
        "RECEIVE_BOOT_COMPLETED",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "WAKE_LOCK",
        "RECEIVE_BOOT_COMPLETED",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "出張記録のため、常に位置情報が必要です。",
          "locationAlwaysPermission": "出張記録のため、常に位置情報が必要です。",
          "locationWhenInUsePermission": "出張記録のため、位置情報が必要です。",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-background-fetch",
        {
          "minimumInterval": 3600
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d3de8250-36a4-406d-933e-c626b05abf51"
      }
    },
    "owner": "sasuga",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d3de8250-36a4-406d-933e-c626b05abf51"
    }
  }
}
